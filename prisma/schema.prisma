generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Run {
  id        String   @id @default(uuid())
  input     String
  createdAt DateTime @default(now())
}

model Event {
  id        String   @id @default(uuid())
  runId     String
  type      String
  data      Json
  createdAt DateTime @default(now())
}