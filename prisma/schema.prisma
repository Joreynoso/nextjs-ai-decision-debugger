generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Run {
  id        String   @id @default(uuid())
  input     String
  createdAt DateTime @default(now())

  events    Event[]
}

model Event {
  id        String   @id @default(uuid())
  runId     String
  type      String
  data      Json
  createdAt DateTime @default(now())

  run       Run       @relation(fields: [runId], references: [id], onDelete: Cascade)
}